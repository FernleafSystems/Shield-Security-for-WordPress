<div class="shield-ipanalyse options_form_for--modern">
	{% if flags.render_inline_tabs %}
		<div class="investigate-panel__tabs" data-investigate-panel-tabs="1">
			{% for tab in tabs %}
				<button type="button"
						class="investigate-panel__tab {{ tab.is_focus ? 'is-active active' : '' }}"
						data-investigate-panel-tab="1"
						data-investigate-panel-target="{{ tab.target }}"
						role="tab"
						aria-controls="{{ tab.controls }}"
						aria-selected="{{ tab.is_focus ? 'true' : 'false' }}">
					{{ tab.label }}
				</button>
			{% endfor %}
		</div>
	{% endif %}

	<div class="shield-options-layout has-rail">
		<aside class="shield-options-rail">
			<div class="shield-options-rail-accent"></div>
			{% include '/components/config/options_rail_tabs.twig' with {
				nav_items: tabs,
				nav_list_class: 'shield-ipanalyse-tabs'
			} only %}
		</aside>

		<div class="shield-options-content">
			<div class="tab-content shield-ipanalyse-content">
				{% for tab in tabs %}
					<section class="tab-pane shield-options-panel {{ tab.is_focus ? 'active show' : '' }}"
							 id="{{ tab.controls }}"
							 role="tabpanel"
							 aria-labelledby="{{ tab.id }}">
						<div class="shield-options-panel-accent"></div>
						<div class="shield-options-panel-body {{ tab.panel_body_class }}">
							{{ attribute(content, tab.content_key)|raw }}
						</div>
					</section>
				{% endfor %}
			</div>
		</div>
	</div>
</div>
