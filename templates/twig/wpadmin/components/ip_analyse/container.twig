<div class="shield-ipanalyse options_form_for--modern">
	{% set tab_id_prefix = 'tabIpInfo-' ~ unique_render_id %}
	{% set tab_nav_prefix = 'tab-navlink-ip-' ~ unique_render_id %}
	{% set rail_nav_items = [
		{
			target: '#' ~ tab_id_prefix ~ '-general',
			id: tab_nav_prefix ~ '-general',
			controls: tab_id_prefix ~ '-general',
			label: strings.nav_general,
			is_focus: true
		},
		{
			target: '#' ~ tab_id_prefix ~ '-signals',
			id: tab_nav_prefix ~ '-signals',
			controls: tab_id_prefix ~ '-signals',
			label: strings.nav_signals,
			is_focus: false
		},
		{
			target: '#' ~ tab_id_prefix ~ '-sessions',
			id: tab_nav_prefix ~ '-sessions',
			controls: tab_id_prefix ~ '-sessions',
			label: strings.nav_sessions,
			is_focus: false
		},
		{
			target: '#' ~ tab_id_prefix ~ '-audit',
			id: tab_nav_prefix ~ '-audit',
			controls: tab_id_prefix ~ '-audit',
			label: strings.nav_audit,
			is_focus: false
		},
		{
			target: '#' ~ tab_id_prefix ~ '-traffic',
			id: tab_nav_prefix ~ '-traffic',
			controls: tab_id_prefix ~ '-traffic',
			label: strings.nav_traffic,
			is_focus: false
		}
	] %}

	<div class="shield-options-layout has-rail">
		<aside class="shield-options-rail">
			<div class="shield-options-rail-accent"></div>
			{% include '/components/config/options_rail_tabs.twig' with {
				nav_items: rail_nav_items,
				nav_list_class: 'shield-ipanalyse-tabs'
			} only %}
		</aside>

		<div class="shield-options-content">
			<div class="tab-content shield-ipanalyse-content">
				<section class="tab-pane shield-options-panel active show"
						 id="{{ tab_id_prefix }}-general"
						 role="tabpanel"
						 aria-labelledby="{{ tab_nav_prefix }}-general">
					<div class="shield-options-panel-accent"></div>
					<div class="shield-options-panel-body">
						{{ content.general|default('no content')|raw }}
					</div>
				</section>
				<section class="tab-pane shield-options-panel"
						 id="{{ tab_id_prefix }}-signals"
						 role="tabpanel"
						 aria-labelledby="{{ tab_nav_prefix }}-signals">
					<div class="shield-options-panel-accent"></div>
					<div class="shield-options-panel-body">
						{{ content.signals|default('no content')|raw }}
					</div>
				</section>
				<section class="tab-pane shield-options-panel"
						 id="{{ tab_id_prefix }}-sessions"
						 role="tabpanel"
						 aria-labelledby="{{ tab_nav_prefix }}-sessions">
					<div class="shield-options-panel-accent"></div>
					<div class="shield-options-panel-body">
						{{ content.sessions|default('no content')|raw }}
					</div>
				</section>
				<section class="tab-pane shield-options-panel"
						 id="{{ tab_id_prefix }}-audit"
						 role="tabpanel"
						 aria-labelledby="{{ tab_nav_prefix }}-audit">
					<div class="shield-options-panel-accent"></div>
					<div class="shield-options-panel-body">
						{{ content.activity|default('no content')|raw }}
					</div>
				</section>
				<section class="tab-pane shield-options-panel"
						 id="{{ tab_id_prefix }}-traffic"
						 role="tabpanel"
						 aria-labelledby="{{ tab_nav_prefix }}-traffic">
					<div class="shield-options-panel-accent"></div>
					<div class="shield-options-panel-body">
						{{ content.traffic|default('no content')|raw }}
					</div>
				</section>
			</div>
		</div>
	</div>
</div>
