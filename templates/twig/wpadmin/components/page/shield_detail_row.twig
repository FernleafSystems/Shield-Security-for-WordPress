{% import '/common/macros.twig' as icwp_macros %}
{% set row_data = row|default({}) %}
{% set default_icons = {
	'good': 'bi bi-check-circle-fill',
	'warning': 'bi bi-exclamation-triangle-fill',
	'critical': 'bi bi-x-circle-fill',
	'info': 'bi bi-info-circle-fill',
	'neutral': 'bi bi-dash-circle'
} %}
{% set default_labels = {
	'good': 'Good',
	'warning': 'Warning',
	'critical': 'Critical',
	'info': 'Info',
	'neutral': 'Neutral'
} %}
{% set status = row_data.status|default('neutral') %}
{% set icon = row_data.status_icon|default(default_icons[status]|default('bi bi-dash-circle')) %}
{% set status_label = row_data.status_label|default(default_labels[status]|default('Status')) %}
{% set badge_status = row_data.badge_status|default(status == 'neutral' ? 'info' : status) %}
{% set expandable = row_data.expandable|default(false) %}
{% set actions = row_data.actions|default([]) %}
{% set explanations = row_data.explanations|default([]) %}
{% set expand_cta_label = row_data.expand_cta_label|default('') %}

<div class="shield-detail-row shield-detail-row--{{ status }}{% if expandable %} shield-detail-row--expandable{% endif %}"
	 {{ icwp_macros.renderAttributes(row_data.attributes|default({})) }}
	 {% if expandable %}
	 data-shield-expand-trigger="1"
	 data-shield-expand-target="{{ row_data.expand_target|default('')|e('html_attr') }}"
	 aria-controls="{{ row_data.expand_target|default('')|e('html_attr') }}"
	 role="button"
	 tabindex="0"
	 aria-expanded="false"
	 {% endif %}>
	<div class="shield-detail-row__icons">
		<span class="shield-detail-row__status-icon shield-detail-row__status-icon--{{ status }}"
			  role="img"
			  aria-label="{{ status_label|e('html_attr') }}">
			<i class="{{ icon }}"></i>
		</span>
		{% if row_data.show_gear|default(false) %}
			<span class="shield-detail-row__gear-icon" aria-hidden="true">
				<i class="bi bi-gear-fill"></i>
			</span>
		{% endif %}
	</div>

	<div class="shield-detail-row__copy">
		<div class="shield-detail-row__heading">
			<span class="shield-detail-row__title">{{ row_data.title|default('') }}</span>
			{% if row_data.count_badge|default(null) is not null and row_data.count_badge > 0 %}
				<span class="shield-badge badge-{{ badge_status }}">{{ row_data.count_badge }}</span>
			{% endif %}
		</div>

		{% if row_data.description|default('') is not empty %}
			<div class="shield-detail-row__desc">{{ row_data.description }}</div>
		{% endif %}

		{% if explanations is not empty %}
			<ul class="shield-detail-row__explanations">
				{% for explanation in explanations %}
					<li>
						{% if status in [ 'warning', 'critical' ] %}
							<span class="shield-detail-row__expl-icon" aria-hidden="true">
								<i class="bi bi-exclamation-circle-fill"></i>
							</span>
						{% endif %}
						<span>{{ explanation }}</span>
					</li>
				{% endfor %}
			</ul>
		{% endif %}

		{% if actions is not empty %}
			<div class="shield-detail-row__actions">
				{% for action in actions %}
					{% set action_type = action.type|default('navigate') %}
					{% set chip_icon = action.icon|default(
						action_type == 'update'
							? 'bi bi-arrow-up-circle-fill'
							: (action_type == 'deactivate' ? 'bi bi-power' : 'bi bi-arrow-right-circle-fill')
					) %}
					{% set tooltip = action.tooltip is defined and action.tooltip is not null ? action.tooltip|trim : '' %}
					{% if action.is_action %}
						<button type="button"
								class="shield-action-chip shield-action-chip--{{ action_type }}"{% if tooltip is not empty %}
								data-bs-toggle="tooltip"
								data-bs-title="{{ tooltip|e('html_attr') }}"{% endif %}{{ icwp_macros.renderAttributes(action.attributes|default({})) }}>
							<i class="{{ chip_icon }}"></i>
							{{ action.label|default('') }}
						</button>
					{% elseif action.href is not empty %}
						<a href="{{ action.href }}"
						   class="shield-action-chip shield-action-chip--{{ action_type }}"{% if tooltip is not empty %}
						   data-bs-toggle="tooltip"
						   data-bs-title="{{ tooltip|e('html_attr') }}"{% endif %}{{ icwp_macros.renderAttributes(action.attributes|default({})) }}>
							<i class="{{ chip_icon }}"></i>
							{{ action.label|default('') }}
						</a>
					{% endif %}
				{% endfor %}
			</div>
		{% endif %}
	</div>

	{% if expandable %}
		<div class="shield-detail-row__end" aria-hidden="true">
			{% if expand_cta_label is not empty %}
				<span class="shield-detail-row__expand-cta">{{ expand_cta_label }}</span>
			{% endif %}
			<i class="bi bi-chevron-right shield-detail-row__chevron" aria-hidden="true"></i>
		</div>
	{% endif %}
</div>
