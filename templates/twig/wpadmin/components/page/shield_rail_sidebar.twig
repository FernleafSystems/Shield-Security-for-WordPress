{% set rail_data = rail|default({}) %}
{% set items = rail_data.items|default([]) %}

<div class="shield-rail-sidebar" id="{{ rail_data.id|default('ShieldRailSidebar')|e('html_attr') }}">
	<div class="shield-rail-sidebar__accent shield-rail-sidebar__accent--{{ rail_data.accent_status|default('good') }}"></div>
	<ul class="shield-rail-sidebar__nav">
		{% for item in items %}
			{% set is_active = item.is_active|default(false) %}
			{% set item_status = item.status|default('neutral') %}
			{% set badge_status = item.badge_status|default(item_status == 'neutral' ? 'info' : item_status) %}
			<li class="shield-rail-sidebar__item{% if is_active %} is-active{% endif %}"
				data-shield-rail-key="{{ item.key|default('')|e('html_attr') }}"
				data-shield-rail-target="{{ item.key|default('')|e('html_attr') }}"
				role="button"
				tabindex="0"
				aria-current="{{ is_active ? 'true' : 'false' }}">
				<span class="shield-rail-sidebar__pip shield-rail-sidebar__pip--{{ item_status }}"></span>
				<span class="shield-rail-sidebar__label">{{ item.label|default('') }}</span>
				{% if item.count|default(0) > 0 %}
					<span class="shield-badge badge-{{ badge_status }} shield-rail-sidebar__badge">
						{{ item.count }}
					</span>
				{% endif %}
			</li>
		{% endfor %}
	</ul>
</div>
