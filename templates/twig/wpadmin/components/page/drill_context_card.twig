{% set strings = context_card.strings %}

<div class="drill-context-card{% if not context_card.has_renderable_context %} d-none{% endif %}"
	 role="status"
	 aria-atomic="true"
	 aria-live="polite"
	 aria-label="{{ strings.context_aria_label }}"
	 data-drill-context-card="{{ context_card.shell_id }}"
	 {% if context_card.has_renderable_context and context_card.mode is not empty %}
	 data-drill-context-mode="{{ context_card.mode }}"{% endif %}>
	<div class="drill-context-card__header">
		<i class="bi bi-compass drill-context-card__header-icon" aria-hidden="true"></i>
		<span class="drill-context-card__header-label">{{ strings.header_label }}</span>
	</div>
	<div class="drill-context-card__path{% if context_card.initial_context.path is empty %} d-none{% endif %}">
		{% for path_segment in context_card.initial_context.path %}
			<span class="drill-context-card__path-segment{% if loop.last %} is-current{% endif %}">{{ path_segment }}</span>
		{% endfor %}
	</div>
	<div class="drill-context-card__section{% if context_card.initial_context.focus is empty %} d-none{% endif %}">
		<div class="drill-context-card__section-label">{{ strings.focus_label }}</div>
		<div class="drill-context-card__focus">{{ context_card.initial_context.focus }}</div>
	</div>
	<div class="drill-context-card__section{% if context_card.initial_context.next_step is empty %} d-none{% endif %}">
		<div class="drill-context-card__section-label">{{ strings.next_step_label }}</div>
		<div class="drill-context-card__next-step">{{ context_card.initial_context.next_step }}</div>
	</div>
</div>
