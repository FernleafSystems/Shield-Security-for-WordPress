<button type="button"
		class="drill-strip"
		data-drill-strip="1"
		data-drill-strip-aria-prefix="{{ strip.aria_prefix }}"
		aria-label="{{ strip.aria_prefix }} {{ strip.label }}">
	<i class="bi bi-arrow-left drill-strip__back" aria-hidden="true"></i>
	<span class="drill-strip__title">{{ strip.label }}</span>
	{% if strip.badge is not empty %}
		<span class="drill-strip__badge shield-badge badge-{{ strip.badge_status }}">{{ strip.badge }}</span>
	{% endif %}
</button>
