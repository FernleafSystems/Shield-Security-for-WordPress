{% set wrapper_class = wrapper_class|default('') %}
{% set body_class = body_class|default('') %}
{% set icon_class = icon_class|default('bi bi-check-circle-fill') %}

<div class="healthy-disclosure{% if wrapper_class is not empty %} {{ wrapper_class }}{% endif %}">
	<button type="button"
			class="healthy-disclosure__toggle"
			data-healthy-disclosure-toggle="1"
			aria-expanded="false">
		<span class="healthy-disclosure__icon">
			<i class="{{ icon_class }}" aria-hidden="true"></i>
		</span>
		<span class="healthy-disclosure__label">{{ label }}</span>
		<span class="healthy-disclosure__chevron">
			<i class="bi bi-chevron-right" aria-hidden="true"></i>
		</span>
	</button>
	<div class="healthy-disclosure__body{% if body_class is not empty %} {{ body_class }}{% endif %}"
		 data-healthy-disclosure-body="1"
		 aria-hidden="true">
		{{ body_html|raw }}
	</div>
</div>
