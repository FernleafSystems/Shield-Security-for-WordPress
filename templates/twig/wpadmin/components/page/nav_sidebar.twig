{% set sidebar = vars.nav_sidebar|default({}) %}

<div id="NavSideBar" class="d-flex flex-column flex-fill">

	{% if sidebar.back_item|default(null) is not empty %}
		{% set back = sidebar.back_item %}
		<a href="{{ back.href|default('#') }}"
		   class="sidebar-back-item {{ back.classes|default([])|join(' ') }}"
		   {% if back.target|default('') is not empty %}target="{{ back.target }}"{% endif %}
		   {% for data_key,data_val in back.data|default([]) %}
			   data-{{ data_key }}="{{ data_val }}"
		   {% endfor %}
		>
			<span class="sidebar-back-icon"><i class="{{ back.img|default('') }}" aria-hidden="true"></i></span>
			<span class="sidebar-back-label">{{ back.title }}</span>
		</a>
	{% endif %}

	<div class="shield-mode-selector">
		{% for mode_item in sidebar.mode_items|default([]) %}
			<a href="{{ mode_item.href|default('#') }}"
			   class="mode-item {{ mode_item.active|default(false) ? 'active' : '' }} {{ mode_item.classes|default([])|join(' ') }}"
			   data-mode="{{ mode_item.mode|default('') }}"
			   {% if mode_item.target|default('') is not empty %}target="{{ mode_item.target }}"{% endif %}
			   {% for data_key,data_val in mode_item.data|default([]) %}
				   data-{{ data_key }}="{{ data_val }}"
			   {% endfor %}
			   {% if mode_item.introjs|default([]) is not empty %}
				   {% if mode_item.introjs.title|default('') is not empty %}
					   data-introtitle="{{ mode_item.introjs.title }}"
				   {% endif %}
				   data-intro="{{ mode_item.introjs.body|default('') }}"
				   data-introposition="right"
			   {% endif %}
			>
				<span class="mode-icon"><i class="{{ mode_item.img|default('') }}" aria-hidden="true"></i></span>
				<span class="mode-label">{{ mode_item.title }}</span>
				{% if mode_item.badge|default([]) is not empty %}
					<span class="mode-badge {{ mode_item.badge.status|default('') is not empty ? 'status-' ~ mode_item.badge.status : '' }}">
						{{ mode_item.badge.text }}
					</span>
				{% endif %}
			</a>
		{% endfor %}
	</div>

	{% set has_dynamic_sections = sidebar.tool_items|default([]) is not empty
		or sidebar.home_license_item|default(null) is not empty
		or sidebar.home_connect_items|default([]) is not empty %}

	{% if has_dynamic_sections %}
		<div class="sidebar-sep"></div>
	{% endif %}

	{% if sidebar.home_license_item|default(null) is not empty %}
		{% set license = sidebar.home_license_item %}
		<a href="{{ license.href|default('#') }}"
		   class="sidebar-license-item {{ license.classes|default([])|join(' ') }}"
		   {% if license.target|default('') is not empty %}target="{{ license.target }}"{% endif %}
		   {% for data_key,data_val in license.data|default([]) %}
			   data-{{ data_key }}="{{ data_val }}"
		   {% endfor %}
		>
			<span class="sidebar-license-icon"><i class="{{ license.img|default('') }}" aria-hidden="true"></i></span>
			<span class="sidebar-license-content">
				<span class="sidebar-license-title">{{ license.title }}</span>
				{% if license.subtitle|default('') is not empty %}
					<span class="sidebar-license-subtitle">{{ license.subtitle }}</span>
				{% endif %}
			</span>
			{% if license.badge|default([]) is not empty %}
				<span class="sidebar-license-badge {{ license.badge.status|default('') is not empty ? 'status-' ~ license.badge.status : '' }}">{{ license.badge.text }}</span>
			{% endif %}
		</a>
	{% endif %}

	{% if sidebar.tool_items|default([]) is not empty %}
		<div class="sidebar-tools">
			{% for tool in sidebar.tool_items %}
				<a href="{{ tool.href|default('#') }}"
				   class="tool-item {{ tool.active|default(false) ? 'active' : '' }} {{ tool.classes|default([])|join(' ') }}"
				   {% if tool.target|default('') is not empty %}target="{{ tool.target }}"{% endif %}
				   {% for data_key,data_val in tool.data|default([]) %}
					   data-{{ data_key }}="{{ data_val }}"
				   {% endfor %}
				>
					{% if tool.img|default('') is not empty %}
						<span class="tool-icon"><i class="{{ tool.img }}" aria-hidden="true"></i></span>
					{% endif %}
					<span class="tool-label">{{ tool.title }}</span>
				</a>
			{% endfor %}
		</div>
	{% endif %}

	{% if sidebar.home_connect_items|default([]) is not empty %}
		<div class="sidebar-connect">
			<div class="sidebar-connect-title">{{ sidebar.home_connect_title|default('Connect') }}</div>
			<div class="sidebar-connect-grid">
				{% for link in sidebar.home_connect_items %}
					<a href="{{ link.href|default('#') }}"
					   class="sidebar-connect-item {{ link.classes|default([])|join(' ') }}"
					   {% if link.target|default('') is not empty %}target="{{ link.target }}"{% endif %}
					   {% for data_key,data_val in link.data|default([]) %}
						   data-{{ data_key }}="{{ data_val }}"
					   {% endfor %}
					>
						{{ link.title }}
					</a>
				{% endfor %}
			</div>
		</div>
	{% endif %}

	{% if not flags.is_whitelabelled %}
		<div class="shield-sidebar-footer mt-auto">{{ strings.running_version|raw }}</div>
	{% endif %}

</div>
