<div class="configure-diagnosis"
	 data-configure-diagnosis="1"
	 data-configure-zone="{{ diagnosis.zone_key }}">
	<div class="zone-summary-header status-{{ diagnosis.zone_status }}">
		<span class="zone-summary-header__icon">
			<i class="{{ diagnosis.zone_icon_class }}" aria-hidden="true"></i>
		</span>
		<div class="zone-summary-header__body">
			<h3 class="zone-summary-header__title">{{ diagnosis.zone_label }}</h3>
			<div class="zone-summary-header__status status-{{ diagnosis.zone_status }}">{{ diagnosis.zone_status_label }}</div>
			<p class="zone-summary-header__context">{{ diagnosis.risk_context }}</p>
		</div>
		<span class="shield-badge badge-{{ diagnosis.strip_badge_status }}">{{ diagnosis.strip_badge }}</span>
	</div>

	{% if diagnosis.problem_rows is not empty %}
		<div class="configure-diagnosis__settings">
			{% for row in diagnosis.problem_rows %}
				<div class="setting-card severity-{{ row.status }}">
					<div class="setting-card__title">{{ row.title }}</div>
					<div class="setting-card__finding">{{ row.summary }}</div>
					{% if row.explanations is not empty %}
						<div class="setting-card__finding">
							{% for explanation in row.explanations %}
								<span class="setting-card__explanation">{{ explanation }}</span>
							{% endfor %}
						</div>
					{% endif %}
					<div class="setting-card__control-row">
						<span class="setting-card__control-label">Current setting</span>
						<span class="setting-card__control-placeholder">
							<i class="{{ row.status_icon_class }}" aria-hidden="true"></i>
						</span>
					</div>
				</div>
			{% endfor %}
		</div>
	{% elseif diagnosis.is_review_state %}
		<div class="setting-card severity-good">
			<div class="setting-card__title">{{ diagnosis.strip_badge }}</div>
			<div class="setting-card__finding">{{ diagnosis.stat_line }}</div>
		</div>
	{% endif %}

	{% if diagnosis.healthy_rows is not empty %}
		<div class="healthy-settings-header" data-configure-healthy-settings-toggle="1">
			<span class="healthy-settings-header__icon">
				<i class="bi bi-check-circle-fill" aria-hidden="true"></i>
			</span>
			<span class="healthy-settings-header__label">
				Looking good &mdash; {{ diagnosis.healthy_rows|length }}
				{{ diagnosis.healthy_rows|length == 1 ? 'setting configured correctly' : 'settings configured correctly' }}
			</span>
			<span class="healthy-settings-header__chevron">
				<i class="bi bi-chevron-right" aria-hidden="true"></i>
			</span>
		</div>
		<div class="healthy-settings-body" data-configure-healthy-settings-body="1">
			{% for row in diagnosis.healthy_rows %}
				<div class="setting-card setting-card--healthy severity-good">
					<div class="setting-card__title">
						<span>{{ row.title }}</span>
						<span class="setting-card__healthy-check">
							<i class="bi bi-check-circle-fill" aria-hidden="true"></i>
						</span>
					</div>
				</div>
			{% endfor %}
		</div>
	{% endif %}

	<div class="configure-diagnosis__next-move">
		<div class="configure-diagnosis__section-title">{{ diagnosis.next_move_heading }}</div>
		<p class="configure-diagnosis__next-move-copy">{{ diagnosis.next_move }}</p>
	</div>
</div>
