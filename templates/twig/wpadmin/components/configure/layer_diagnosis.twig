{% set diagnosis_id = 'configure-diagnosis-' ~ diagnosis.zone_key %}
{% set empty_expand = {
	id: '',
	parent_id: '',
	is_expandable: false,
	label: '',
	title: '',
	data_attributes: {}
} %}

<div class="configure-diagnosis"
	 data-configure-diagnosis="1"
	 data-configure-zone="{{ diagnosis.zone_key }}"
	 id="{{ diagnosis_id }}">
	{% if diagnosis.problem_rows is not empty %}
		<div class="configure-diagnosis__settings">
			{% for row in diagnosis.problem_rows %}
				{% set expand_id = diagnosis_id ~ '-problem-expand-' ~ loop.index0 %}
				{% include '/wpadmin/components/configure/detail_item.twig' with { item: {
					row: {
						title: row.title,
						description: row.summary,
						status: row.status,
						status_icon: row.status_icon_class,
						status_label: row.status_label,
						explanations: row.explanations,
						attributes: {}
					},
					expand: {
						id: expand_id,
						parent_id: diagnosis_id,
						is_expandable: row.expand_action.is_expandable,
						label: row.expand_action.label,
						title: row.expand_action.title,
						data_attributes: row.expand_action.data_attributes
					}
				} } only %}
			{% endfor %}
		</div>
	{% endif %}

	{% if diagnosis.review_rows is not empty or diagnosis.review_fallback_card is not empty %}
		<div class="configure-diagnosis__review">
			<div class="configure-diagnosis__section-title">{{ diagnosis.review_rows_heading }}</div>
			<div class="configure-diagnosis__settings">
				{% for row in diagnosis.review_rows %}
					{% set expand_id = diagnosis_id ~ '-review-expand-' ~ loop.index0 %}
					{% include '/wpadmin/components/configure/detail_item.twig' with { item: {
						row: {
							title: row.title,
							description: row.summary,
							status: row.status,
							status_icon: row.status_icon_class,
							status_label: row.status_label,
							explanations: row.explanations,
							attributes: {}
						},
						expand: {
							id: expand_id,
							parent_id: diagnosis_id,
							is_expandable: row.expand_action.is_expandable,
							label: row.expand_action.label,
							title: row.expand_action.title,
							data_attributes: row.expand_action.data_attributes
						}
					} } only %}
				{% endfor %}

				{% if diagnosis.review_fallback_card is not empty %}
					{% include '/wpadmin/components/configure/detail_item.twig' with { item: {
						row: {
							title: diagnosis.review_fallback_card.title,
							description: diagnosis.review_fallback_card.summary,
							status: diagnosis.review_fallback_card.status,
							status_icon: diagnosis.review_fallback_card.status_icon_class,
							status_label: diagnosis.review_fallback_card.status_label,
							attributes: {}
						},
						expand: empty_expand
					} } only %}
				{% endif %}
			</div>
		</div>
	{% endif %}

	{% if diagnosis.healthy_rows is not empty %}
		{% set body_html %}
			{% for row in diagnosis.healthy_rows %}
				{% set expand_id = diagnosis_id ~ '-healthy-expand-' ~ loop.index0 %}
				{% include '/wpadmin/components/configure/detail_item.twig' with { item: {
					row: {
						title: row.title,
						description: row.summary,
						status: row.status,
						status_icon: row.status_icon_class,
						status_label: row.status_label,
						explanations: row.explanations,
						attributes: {}
					},
					expand: {
						id: expand_id,
						parent_id: diagnosis_id,
						is_expandable: row.expand_action.is_expandable,
						label: row.expand_action.label,
						title: row.expand_action.title,
						data_attributes: row.expand_action.data_attributes
					}
				} } only %}
			{% endfor %}
		{% endset %}
		{% include '/wpadmin/components/page/healthy_disclosure.twig' with {
			label: diagnosis.healthy_rows_heading,
			body_html: body_html
		} only %}
	{% endif %}

	<div class="configure-diagnosis__next-move">
		<div class="configure-diagnosis__section-title">{{ diagnosis.next_move_heading }}</div>
		<p class="configure-diagnosis__next-move-copy">{{ diagnosis.next_move }}</p>
		{% if diagnosis.settings_href is not empty %}
			<a href="{{ diagnosis.settings_href }}" class="configure-diagnosis__settings-link">
				{{ diagnosis.settings_label }} <i class="bi bi-arrow-right" aria-hidden="true"></i>
			</a>
		{% endif %}
	</div>
</div>
