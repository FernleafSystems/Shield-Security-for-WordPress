{% macro zone_card(zone) %}
	<button type="button"
			class="configure-zone-card status-{{ zone.status }}"
			data-drill-target="diagnosis"
			data-drill-zone-selection="{{ zone.selection_json }}"
			{% if zone.is_disabled %}disabled{% endif %}>
		<span class="configure-zone-card__icon">
			<i class="{{ zone.icon_class }}" aria-hidden="true"></i>
		</span>
		<div class="configure-zone-card__body">
			<h4 class="configure-zone-card__title">{{ zone.label }}</h4>
			<div class="configure-zone-card__status">{{ zone.status_label }}</div>
			<p class="configure-zone-card__oneliner">{{ zone.preview_text }}</p>
		</div>
	</button>
{% endmacro %}

{% from _self import zone_card %}

<div class="configure-zones">
	{% for section in sections %}
		{% if section.cards is not empty %}
			{% if section.collapsible %}
				{% set body_html %}
					<div class="configure-zones__grid">
						{% for zone in section.cards %}
							{{ zone_card(zone) }}
						{% endfor %}
					</div>
				{% endset %}
				{% include '/wpadmin/components/page/healthy_disclosure.twig' with {
					label: section.cards|length ~ ' ' ~ section.heading|lower,
					body_html: body_html
				} only %}
			{% else %}
				<section class="configure-zones__section">
					<div class="configure-zones__grid">
						{% for zone in section.cards %}
							{{ zone_card(zone) }}
						{% endfor %}
					</div>
				</section>
			{% endif %}
		{% endif %}
	{% endfor %}
</div>
