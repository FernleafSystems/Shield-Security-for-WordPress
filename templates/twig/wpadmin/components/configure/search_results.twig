<div class="configure-search-results"
	 data-configure-search-results="1">
	{% if flags.has_results %}
		<div class="configure-search-results__list">
			{% for result in vars.results %}
				<a class="configure-search-results__item"
				   data-configure-search-result="1"
				   data-drill-zone-selection="{{ result.selection_json|e('html_attr') }}"
				   data-configure-focus-request="{{ result.focus_request_json|e('html_attr') }}"
				   href="{{ result.href }}">
					<span class="configure-search-results__icon">
						<i class="{{ result.icon_class }}" aria-hidden="true"></i>
					</span>
					<span class="configure-search-results__copy">
						<span class="configure-search-results__type configure-search-results__type--{{ result.type }}">
							{{ result.type == 'zone' ? strings.zone_label : strings.option_label }}
						</span>
						<span class="configure-search-results__label">{{ result.label }}</span>
						{% if result.summary is not empty %}
							<span class="configure-search-results__summary">{{ result.summary }}</span>
						{% endif %}
					</span>
				</a>
			{% endfor %}
		</div>
	{% else %}
		<p class="configure-search-results__empty mb-0">{{ strings.no_results }}</p>
	{% endif %}
</div>
