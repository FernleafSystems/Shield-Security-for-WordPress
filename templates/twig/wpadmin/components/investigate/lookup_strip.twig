{% set lookup_behavior = lookup_behavior|default({}) %}
{% set is_panel_form = lookup_behavior.panel_form|default(panel_form|default(false)) %}
{% set is_select2 = lookup_behavior.use_select2|default(use_select2|default(false)) %}
{% set is_auto_submit_on_change = lookup_behavior.auto_submit_on_change|default(auto_submit_on_change|default(false)) %}

<section class="investigate-lookup-strip">
	<form method="get"
		  action="{{ action }}"
		  class="investigate-lookup-strip__form"
		  {% if is_panel_form %}
		  data-investigate-panel-form="1"
		  {% endif %}>
		{% include '/wpadmin/components/investigate/lookup_route_hidden_inputs.twig' with {
			lookup_route: lookup_route
		} only %}

		<div class="investigate-lookup-strip__field">
			<label class="form-label mb-1">{{ label }}</label>
			{% if input_type == 'select' %}
				<select name="{{ input_name }}"
						class="form-select{% if is_select2 %} investigate-lookup-select2{% endif %}"
						{% if is_select2 %}
						data-investigate-select2="1"
						{% endif %}
						{% if is_auto_submit_on_change %}
						data-investigate-auto-submit="1"
						{% endif %}>
					<option value="">{{ placeholder|default('') }}</option>
					{% for option in options|default([]) %}
						<option value="{{ option.value }}" {{ input_value == option.value ? 'selected' : '' }}>
							{{ option.label }}
						</option>
					{% endfor %}
				</select>
			{% else %}
				<input type="text"
					   name="{{ input_name }}"
					   value="{{ input_value|default('') }}"
					   class="form-control"
					   placeholder="{{ placeholder|default('') }}"/>
			{% endif %}
		</div>

		<div class="investigate-lookup-strip__submit">
			<button type="submit" class="btn btn-outline-primary">{{ submit_text }}</button>
		</div>
	</form>
</section>
