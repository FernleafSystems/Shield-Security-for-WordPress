<section class="investigate-flat-section">
	<div class="d-flex justify-content-between align-items-start gap-2">
		<div>
			<h5 class="mb-2 investigate-section-title">{{ vulnerabilities.title|default('') }}</h5>
			<p class="mb-0">{{ vulnerabilities.summary|default('') }}</p>
		</div>
		{% if vulnerabilities.lookup_href|default('') is not empty %}
			<a href="{{ vulnerabilities.lookup_href }}" target="_blank" class="btn btn-outline-secondary btn-sm">{{ vulnerabilities.lookup_text|default('Lookup') }}</a>
		{% endif %}
	</div>
</section>
