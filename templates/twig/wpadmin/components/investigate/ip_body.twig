{# TODO: If this partial gains another UI mode or consumer, replace the ad hoc ui overlay with a dedicated view-model contract. #}
{% set show_lookup_with_subject = ui.show_lookup_with_subject|default(false) %}
{% set show_subject_header = ui.show_subject_header|default(true) %}
{% set change_label = ui.change_label|default('') %}

{% if flags.has_subject %}
	{% if show_subject_header %}
		{% include '/wpadmin/components/investigate/subject_header.twig' with {
			title: vars.subject_header.title,
			meta: vars.subject_header.meta,
			change_label: change_label
		} only %}
	{% endif %}
	{% if show_lookup_with_subject %}
		{% include '/wpadmin/components/investigate/lookup_strip.twig' with {
			action: hrefs.by_ip,
			lookup_route: vars.lookup_route,
			lookup_behavior: vars.lookup_behavior,
			lookup_ajax: vars.lookup_ajax,
			offcanvas_history_mode: vars.offcanvas_history_mode|default(''),
			label: strings.lookup_label,
			input_name: 'analyse_ip',
			input_type: 'select',
			input_value: vars.analyse_ip,
			selected_option_label: vars.analyse_ip,
			options: [],
			placeholder: strings.lookup_placeholder,
			submit_text: strings.lookup_submit,
			helper_text: strings.lookup_helper
		} only %}
	{% endif %}
	<div class="investigate-inline-ipanalyse">
		{% if show_lookup_with_subject %}
			<div class="investigate-panel__tabs" data-investigate-panel-tabs="1"></div>
		{% endif %}
		{{ content.ip_analysis|raw }}
	</div>
{% else %}
	{% include '/wpadmin/components/investigate/lookup_strip.twig' with {
		action: hrefs.by_ip,
		lookup_route: vars.lookup_route,
		lookup_behavior: vars.lookup_behavior,
		lookup_ajax: vars.lookup_ajax,
		offcanvas_history_mode: vars.offcanvas_history_mode|default(''),
		label: strings.lookup_label,
		input_name: 'analyse_ip',
		input_type: 'select',
		input_value: vars.analyse_ip,
		selected_option_label: vars.analyse_ip,
		options: [],
		placeholder: strings.lookup_placeholder,
		submit_text: strings.lookup_submit,
		helper_text: strings.lookup_helper
	} only %}
	<div class="investigate-empty-state-text">{{ strings.no_subject_text }}</div>
{% endif %}
