<section class="card shield-card investigate-landing__subject-panel status-info"
		 data-investigate-panel="1"
		 data-investigate-panel-subject="{{ panel.subject_key }}"
		 data-investigate-panel-loaded="{{ panel.is_loaded }}"
		 data-investigate-panel-live="{{ panel.is_live }}"
		 data-investigate-render-action="{{ panel.render_action_json }}">
	<div class="shield-card-accent status-info"></div>
	<div class="card-body">
		<div data-investigate-panel-header="1"></div>
		<div class="investigate-panel__tabs" data-investigate-panel-tabs="1"></div>
		<div data-investigate-panel-content="1">
			{{ panel.body|raw }}
		</div>
	</div>
</section>
