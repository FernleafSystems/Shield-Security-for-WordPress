<div class="actions-queue-groups"
	 data-actions-queue-groups="1">
	<div class="actions-queue-groups__intro">
		<div class="actions-queue-groups__eyebrow">{{ bucket_selection.label }}</div>
		<div class="actions-queue-groups__summary">{{ strip_text }}</div>
	</div>

	{% if groups is empty %}
		<div class="actions-landing__empty-state">
			{{ empty_message }}
		</div>
	{% else %}
		<div class="actions-queue-groups__grid">
			{% for group in groups %}
				<button type="button"
						class="actions-queue-group-card shield-card status-{{ group.status }}"
						data-drill-target="detail"
						data-drill-bucket-selection="{{ bucket_selection_json }}"
						data-drill-group-selection="{{ group.selection_json }}">
					<div class="shield-card-accent status-{{ group.status }}"></div>
					<div class="actions-queue-group-card__header">
						<div class="actions-queue-group-card__title-wrap">
							<div class="actions-queue-group-card__icon">
								<i class="{{ group.icon_class }}" aria-hidden="true"></i>
							</div>
							<div>
								<div class="actions-queue-group-card__title">{{ group.label }}</div>
								<div class="actions-queue-group-card__narrative">{{ group.narrative }}</div>
							</div>
						</div>
						<span class="shield-badge badge-{{ group.status }}">{{ group.item_count }}</span>
					</div>
					<div class="actions-queue-group-card__next-move">
						<i class="bi bi-arrow-right-circle" aria-hidden="true"></i>
						{{ group.next_move }}
					</div>
				</button>
			{% endfor %}
		</div>
	{% endif %}
</div>
