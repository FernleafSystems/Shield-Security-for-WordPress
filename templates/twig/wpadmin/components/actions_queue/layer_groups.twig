<div class="actions-queue-groups"
	 data-actions-queue-groups="1">
	<div class="actions-queue-groups__intro">
		<div class="actions-queue-groups__eyebrow">{{ bucket_selection.label }}</div>
		<div class="actions-queue-groups__summary">{{ strip_text }}</div>
	</div>

	{% if groups is empty %}
		<div class="actions-landing__empty-state">
			{{ empty_message }}
		</div>
	{% else %}
		<div class="actions-queue-groups__findings">
			{% set previous_heading = '' %}
			{% for group in groups %}
				{% if group.card_type == 'category' %}
					<div class="item-box">
						<div class="item-box__header">
							<span class="item-box__header-icon"><i class="{{ group.icon_class }}" aria-hidden="true"></i></span>
							<span class="item-box__header-title">{{ group.label }}</span>
							{% if group.management_link is not empty %}
								<a class="item-box__header-link"
								   href="{{ group.management_link.href }}"
								   {% if group.management_link.target is not empty %}target="{{ group.management_link.target }}"{% endif %}
								   {% if group.management_link.rel is not empty %}rel="{{ group.management_link.rel }}"{% endif %}>
									{{ group.management_link.label }} <i class="bi {{ group.management_link.icon_class }}" aria-hidden="true"></i>
								</a>
							{% endif %}
						</div>
						<div class="item-box__grid">
							{% if group.maintenance_rows is not empty %}
								{% for row in group.maintenance_rows %}
									{% set row_action = row.secondary_actions|default([])|first %}
									{% set row_meta = row.context is not empty ? row.context : row.subtitle %}
									<div class="item-box__row{% if row.is_ignored|default(false) %} is-ignored{% endif %}"
										 {% if row.is_ignored|default(false) %}data-actions-queue-maintenance-ignored="1"{% endif %}>
										<span class="item-box__row-text item-box__row-text--stacked">
											<span class="item-box__row-title">
												<strong>{{ row.title }}</strong>
												{% if row.ignored_label|default('') is not empty %}
													<span class="shield-badge badge-info item-box__row-badge">{{ row.ignored_label }}</span>
												{% endif %}
											</span>
											{% if row_meta is not empty %}
												<span class="item-box__row-summary">{{ row_meta }}</span>
											{% endif %}
										</span>
										{% if row_action is not empty %}
											<a href="{{ row_action.href|default('javascript:{}') }}"
											   class="btn btn-sm btn-light action actions-landing__table-icon-action item-box__row-action"
											   data-bs-toggle="tooltip"
											   data-bs-title="{{ row_action.tooltip|default(row_action.label)|e('html_attr') }}"
											   {% if row_action.target is defined and row_action.target is not empty %}target="{{ row_action.target }}"{% endif %}
											   {% if row_action.ajax_action is defined and row_action.ajax_action is not empty %}data-actions-queue-maintenance-action="{{ row_action.ajax_action|json_encode|e('html_attr') }}"{% endif %}>
												<i class="{{ row_action.icon }}" aria-hidden="true"></i>
												<span class="visually-hidden">{{ row_action.label }}</span>
											</a>
										{% endif %}
									</div>
								{% endfor %}
							{% else %}
								<div class="item-box__row">
									<span class="item-box__row-icon"><i class="{{ group.icon_class }}" aria-hidden="true"></i></span>
									<span class="item-box__row-text">
										<strong>{{ group.narrative }}</strong>{{ group.next_move }}
									</span>
								</div>
							{% endif %}
						</div>
					</div>
				{% else %}
					{% if group.heading_label is not empty and group.heading_label != previous_heading %}
						<div class="finding-group__heading">{{ group.heading_label }}</div>
						{% set previous_heading = group.heading_label %}
					{% endif %}

					{% if group.card_type == 'linked' %}
						<div class="finding-card status-{{ group.status }}">
							<span class="finding-card__icon status-{{ group.status }}">
								<i class="{{ group.icon_class }}" aria-hidden="true"></i>
							</span>
							<div class="finding-card__body">
								<div class="finding-card__title">{{ group.label }}</div>
								<div class="finding-card__desc">{{ group.narrative }}</div>
							</div>
							{% if group.links is not empty %}
								<div class="finding-card__links">
									{% for link in group.links %}
										<a class="finding-card__link"
										   href="{{ link.href }}"
										   {% if link.target is not empty %}target="{{ link.target }}"{% endif %}
										   {% if link.rel is not empty %}rel="{{ link.rel }}"{% endif %}>
											{{ link.label }}{% if link.icon_class is not empty %} <i class="bi {{ link.icon_class }}" aria-hidden="true"></i>{% endif %}
										</a>
									{% endfor %}
								</div>
							{% endif %}
						</div>
					{% else %}
						<button type="button"
								class="finding-card finding-card--expandable status-{{ group.status }}"
								data-drill-target="detail"
								data-drill-bucket-selection="{{ bucket_selection_json }}"
								data-drill-group-selection="{{ group.selection_json }}">
							<span class="finding-card__icon status-{{ group.status }}">
								<i class="{{ group.icon_class }}" aria-hidden="true"></i>
							</span>
							<div class="finding-card__body">
								<div class="finding-card__title">{{ group.label }}</div>
								<div class="finding-card__desc">{{ group.narrative }}</div>
								{% if group.drill_hint is not empty %}
									<div class="finding-card__drill-hint">
										{{ group.drill_hint }} <i class="bi bi-arrow-right" aria-hidden="true"></i>
									</div>
								{% endif %}
							</div>
							<span class="finding-card__chevron">
								<i class="bi bi-chevron-right" aria-hidden="true"></i>
							</span>
						</button>
					{% endif %}
				{% endif %}
			{% endfor %}
		</div>
	{% endif %}
</div>
