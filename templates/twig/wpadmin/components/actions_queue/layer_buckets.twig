<div class="actions-queue-buckets">
	{% if heading is not empty %}
		<div class="actions-queue-buckets__heading">{{ heading }}</div>
	{% endif %}
	<div class="actions-queue-buckets__grid">
		{% for bucket in buckets %}
			<button type="button"
					class="actions-queue-bucket-card status-{{ bucket.status }}{% if bucket.item_count < 1 %} is-empty{% endif %}"
					data-drill-target="groups"
					data-drill-bucket-selection="{{ bucket.selection_json }}"
					{% if bucket.item_count < 1 %}disabled{% endif %}>
				<div class="actions-queue-bucket-card__severity">
					<span class="actions-queue-bucket-card__severity-label">{{ bucket.status == 'warning' ? 'Review' : bucket.status|capitalize }}</span>
					<span class="actions-queue-bucket-card__count">{{ bucket.item_count }}</span>
				</div>
				<div class="actions-queue-bucket-card__title">{{ bucket.label }}</div>
				<div class="actions-queue-bucket-card__summary">{{ bucket.summary_text }}</div>
			</button>
		{% endfor %}
	</div>
	{% if looking_good is defined and looking_good.items is not empty %}
		<div class="item-box item-box--good is-dimmed-healthy" style="margin-top: 1rem;">
			<div class="item-box__header">
				<span class="item-box__header-icon"><i class="bi bi-patch-check-fill" aria-hidden="true"></i></span>
				<span class="item-box__header-title">{{ looking_good.heading }}</span>
			</div>
			<div class="item-box__grid">
				{% for item in looking_good.items %}
					<div class="item-box__row">
						<span class="item-box__row-icon"><i class="{{ item.icon_class }}" aria-hidden="true"></i></span>
						<span class="item-box__row-text">
							<strong>{{ item.title }}</strong>{{ item.summary }}
						</span>
					</div>
				{% endfor %}
			</div>
		</div>
	{% endif %}
</div>
