{% if group.card_type == 'linked' %}
	<div class="finding-card status-{{ group.status }}">
		<span class="finding-card__icon status-{{ group.status }}">
			<i class="{{ group.icon_class }}" aria-hidden="true"></i>
		</span>
		<div class="finding-card__body">
			<div class="finding-card__title">{{ group.label }}</div>
			<div class="finding-card__desc">{{ group.narrative }}</div>
		</div>
		{% if group.links is not empty %}
			<div class="finding-card__links">
				{% for link in group.links %}
					<a class="finding-card__link"
					   href="{{ link.href }}"
					   {% if link.target is not empty %}target="{{ link.target }}"{% endif %}
					   {% if link.rel is not empty %}rel="{{ link.rel }}"{% endif %}>
						{{ link.label }}{% if link.icon_class is not empty %} <i class="bi {{ link.icon_class }}" aria-hidden="true"></i>{% endif %}
					</a>
				{% endfor %}
			</div>
		{% endif %}
	</div>
{% elseif group.is_interactive %}
	<button type="button"
			class="finding-card finding-card--expandable status-{{ group.status }}"
			data-drill-target="detail"
			data-drill-bucket-selection="{{ bucket_selection.selection_json }}"
			data-drill-group-selection="{{ group.selection_json }}">
		<span class="finding-card__icon status-{{ group.status }}">
			<i class="{{ group.icon_class }}" aria-hidden="true"></i>
		</span>
		<div class="finding-card__body">
			<div class="finding-card__title">{{ group.label }}</div>
			<div class="finding-card__desc">{{ group.narrative }}</div>
			{% if group.drill_hint is not empty %}
				<div class="finding-card__drill-hint">
					{{ group.drill_hint }} <i class="bi bi-arrow-right" aria-hidden="true"></i>
				</div>
			{% endif %}
		</div>
		<span class="finding-card__chevron">
			<i class="bi bi-chevron-right" aria-hidden="true"></i>
		</span>
	</button>
{% else %}
	<div class="finding-card status-{{ group.status }}">
		<span class="finding-card__icon status-{{ group.status }}">
			<i class="{{ group.icon_class }}" aria-hidden="true"></i>
		</span>
		<div class="finding-card__body">
			<div class="finding-card__title">{{ group.label }}</div>
			<div class="finding-card__desc">{{ group.narrative }}</div>
		</div>
	</div>
{% endif %}
