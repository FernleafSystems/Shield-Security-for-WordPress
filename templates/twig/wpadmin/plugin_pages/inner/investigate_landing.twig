{% extends '/wpadmin/plugin_pages/base_inner_page.twig' %}

{% block inner_page_body %}
	{% set active_subject = vars.active_subject|default('') %}

	<div class="investigate-landing" data-investigate-landing="1">
		<section class="investigate-landing__selector-shell" data-investigate-section="selector">
			<div class="investigate-landing__subject-grid" data-mode-tiles="1">
				{% for subject in vars.subjects %}
					{% set is_active = subject.is_enabled and active_subject == subject.key %}
					{% if subject.is_enabled %}
						<button type="button"
								class="investigate-landing__subject-card status-{{ subject.status }}{% if is_active %} is-active{% endif %}"
								data-investigate-subject="{{ subject.key }}"
								data-mode-tile="1"
								data-mode-tile-key="{{ subject.key }}"
								data-mode-panel-target="{{ subject.panel_target }}"
								aria-expanded="{{ is_active ? 'true' : 'false' }}">
							<span class="investigate-landing__subject-icon" aria-hidden="true">
								<i class="{{ subject.icon_class }}"></i>
							</span>
							<span class="investigate-landing__subject-label">
								{{ subject.title }}
								{% if subject.is_pro %}
									<span class="shield-badge badge-warning">{{ strings.label_pro }}</span>
								{% endif %}
							</span>
							<span class="investigate-landing__subject-stat">{{ subject.stat_text }}</span>
						</button>
					{% else %}
						<div class="investigate-landing__subject-card is-disabled status-{{ subject.status }}"
							 data-investigate-subject="{{ subject.key }}"
							 data-mode-tile="1"
							 data-mode-tile-key="{{ subject.key }}"
							 data-mode-panel-target="{{ subject.panel_target }}"
							 data-mode-tile-disabled="1"
							 aria-disabled="true">
							<span class="investigate-landing__subject-icon" aria-hidden="true">
								<i class="{{ subject.icon_class }}"></i>
							</span>
							<span class="investigate-landing__subject-label">
								{{ subject.title }}
								{% if subject.is_pro %}
									<span class="shield-badge badge-warning">{{ strings.label_pro }}</span>
								{% endif %}
							</span>
							<span class="investigate-landing__subject-stat">{{ subject.stat_text }}</span>
						</div>
					{% endif %}
				{% endfor %}
			</div>
		</section>

		{% for subject in vars.subjects if subject.is_enabled %}
			{% set is_open = active_subject == subject.key %}
			{% include '/wpadmin/components/page/mode_panel_shell.twig' with {
				panel: {
					id: 'InvestigateModePanel-' ~ subject.key,
					class: 'investigate-landing__subject-panel' ~ (is_open ? ' is-open' : ''),
					is_open: is_open,
					target: subject.panel_target,
					target_default: subject.panel_target,
					static_target: true,
					status: subject.panel_status,
					title: subject.panel_title,
					body: subject.panel_body,
					data: {
						'investigate-panel': subject.key,
						'investigate-render-action': subject.render_action|default({})|json_encode
					}
				},
				strings: strings
			} only %}
		{% endfor %}
	</div>
{% endblock %}
