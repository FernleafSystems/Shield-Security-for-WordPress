{% extends '/wpadmin/plugin_pages/base_inner_page.twig' %}

{% block inner_page_body %}
	<div class="configure-landing"
		 data-configure-landing="1"
		 data-configure-render-action="{{ vars.configure_render_action|default({})|json_encode|e('html_attr') }}">
		<div data-configure-section="hero">
			<div class="configure-landing__posture-strip shield-mode-strip shield-card status-{{ vars.posture_status|default('good') }}">
				{% include '/wpadmin/components/page/mode_status_strip.twig' with {
					strip: {
						status: vars.posture_status|default('good'),
						chip_label: vars.posture_label|default(''),
						icon_class: vars.posture_icon_class|default(''),
						eyebrow: strings.posture_title|default(''),
						summary: vars.posture_summary|default(''),
						meter: {
							percentage: vars.posture_percentage|default(0),
							status: vars.posture_status|default('good'),
							aria_label: strings.posture_title|default('Configuration posture'),
							aria_value_text: vars.posture_percentage|default(0) ~ '%'
						}
					}
				} only %}
			</div>
		</div>

		<div class="mt-4" data-configure-section="zones">
			{% include '/wpadmin/components/configure/configure_rail.twig' with {
				vars: vars,
				strings: strings
			} only %}
		</div>
	</div>
{% endblock %}
