{% extends '/wpadmin/plugin_pages/base_inner_page.twig' %}

{% block inner_page_body %}
	<div class="configure-landing" data-configure-landing="1">
		<div data-configure-section="hero">
			<div class="configure-landing__posture-strip" data-configure-posture-strip="1">
				<span class="configure-landing__posture-chip status-{{ vars.posture_status }}"
					  data-configure-posture-chip="1">
					<i class="{{ vars.posture_icon_class }}" aria-hidden="true"></i>
					{{ vars.posture_label }}
				</span>
				<div class="configure-landing__posture-info">
					<div class="configure-landing__posture-bar-wrap">
						<div class="configure-landing__posture-bar status-{{ vars.posture_status }}"
							 data-configure-posture-bar="1"
							 style="width: {{ vars.posture_percentage|default(0) }}%;"></div>
					</div>
					<span class="configure-landing__posture-summary" data-configure-posture-summary="1">
						{{ vars.posture_summary|default('') }}
					</span>
				</div>
			</div>
		</div>

		<div class="mt-4" data-configure-section="zones">
			<h5 class="card-title mb-1">{{ strings.zones_title }}</h5>
			<p class="text-muted small mb-3">{{ strings.zones_subtitle }}</p>
			<div class="configure-landing__zone-grid" data-mode-tiles="1">
				{% for zone in vars.zone_tiles %}
					<button type="button"
							class="configure-landing__zone-tile status-{{ zone.status }}{% if zone.is_disabled %} is-disabled{% endif %}"
							data-configure-zone="{{ zone.key }}"
							data-mode-tile="1"
							data-mode-tile-key="{{ zone.key }}"
							data-mode-panel-target="{{ zone.panel_target }}"
							data-mode-tile-disabled="{{ zone.is_disabled ? '1' : '0' }}"
							aria-disabled="{{ zone.is_disabled ? 'true' : 'false' }}"
							aria-expanded="false">
						<span class="configure-landing__zone-tile-header">
							<span class="configure-landing__zone-tile-icon"><i class="{{ zone.icon_class }}" aria-hidden="true"></i></span>
							<span class="configure-landing__zone-status status-{{ zone.status }}">{{ zone.status_label }}</span>
						</span>
						<span class="configure-landing__zone-title">{{ zone.label }}</span>
						<span class="configure-landing__zone-stat">{{ zone.stat_line }}</span>
					</button>
				{% endfor %}
			</div>
		</div>

		{% for zone in vars.zone_tiles %}
			{% set panel_body %}
				{% include '/wpadmin/components/configure/zone_panel_body.twig' with {
					zone: zone
				} only %}
			{% endset %}
			{% include '/wpadmin/components/page/mode_panel_shell.twig' with {
				panel: {
					id: 'ConfigureModePanel-' ~ zone.key,
					class: 'configure-landing__zone-panel',
					target: zone.panel_target,
					target_default: zone.panel_target,
					static_target: true,
					status: zone.panel.status,
					title: zone.panel.title,
					badge_label: zone.panel.status_label,
					badge_class: 'configure-landing__zone-status status-' ~ zone.panel.status,
					body: panel_body,
					data: {
						'configure-panel': zone.key
					}
				},
				strings: strings
			} only %}
		{% endfor %}
	</div>
{% endblock %}
