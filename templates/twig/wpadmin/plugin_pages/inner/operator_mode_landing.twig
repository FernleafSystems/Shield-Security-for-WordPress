<div class="operator-mode-landing">
	<div class="mode-selector-grid" data-mode-selector-grid="1">
		{% for cell in vars.mode_grid_cells|default([]) %}
			<a href="{{ cell.href }}"
			   class="mode-selector-cell"
			   data-mode="{{ cell.mode }}"
			   aria-label="{{ cell.label }}">
				<span class="mode-selector-cell-icon"><i class="{{ cell.icon_class }}" aria-hidden="true"></i></span>
				<span class="mode-selector-cell-title">{{ cell.label }}</span>
				<span class="mode-selector-cell-description">{{ cell.description }}</span>

				{% if cell.indicator_type == 'posture' %}
					<span class="cell-posture-wrap">
						<span class="cell-posture-track">
							<span class="cell-posture-fill status-{{ cell.posture_status }}" style="width: {{ cell.posture_percentage }}%"></span>
						</span>
						<span class="cell-posture-label status-{{ cell.posture_status }}">{{ cell.posture_text }}</span>
					</span>
				{% else %}
					<span class="cell-status-bar {{ cell.indicator_class|default('status-neutral') }}">{{ cell.indicator_text }}</span>
					{% if cell.indicator_subtext|default('') is not empty %}
						<span class="cell-status-subtext">{{ cell.indicator_subtext }}</span>
					{% endif %}
				{% endif %}

				{% if cell.footnote|default('') is not empty %}
					<span class="mode-selector-cell-footnote">{{ cell.footnote }}</span>
				{% endif %}
			</a>
		{% endfor %}
	</div>
</div>
