{% extends '/wpadmin/plugin_pages/base_inner_page.twig' %}

{% block inner_page_body %}
	<div class="license-page">
		{% if flags.is_pro or flags.has_licence %}
			<div class="sp-panel">
				<div class="sp-panel-accent {{ vars.status_card.accent_class }}"></div>
				<div class="status-card-body">
					<div class="status-orb {{ vars.status_card.orb_class }}">
						<i class="{{ vars.status_card.orb_icon }}" aria-hidden="true"></i>
					</div>
					<div class="flex-grow-1">
						<div class="status-eyebrow">{{ strings.license_status_eyebrow }}</div>
						<h2 class="status-title">
							{{ vars.status_card.title }}
							<span class="sp-badge {{ vars.status_card.badge_class }}">
								<i class="{{ vars.status_card.badge_icon }}" aria-hidden="true"></i>
								{{ vars.status_card.badge_text }}
							</span>
						</h2>
						<p class="status-sub{% if vars.status_card.is_expired %} danger{% endif %}">{{ vars.status_card.subtitle }}</p>
						<div class="lic-row-grid">
							{% for license_key, license_val in vars.license_table %}
								{% if license_val is not empty %}
									<div>
										<div class="lic-row-item-label">{{ attribute(strings, license_key) }}</div>
										<div class="lic-row-item-value{% if license_key == 'installation_id' %} mono{% endif %}{% if vars.status_card.is_expired and license_key == 'license_expires' %} danger{% endif %}">{{ license_val|raw }}</div>
									</div>
								{% endif %}
							{% endfor %}
						</div>
					</div>
				</div>
				<div class="status-card-footer">
					{% if vars.status_card.is_expired %}
						<a href="{{ hrefs.shield_pro_url }}"
						   target="_blank"
						   rel="noopener noreferrer"
						   class="btn btn-danger">
							<i class="bi bi-arrow-right-circle" aria-hidden="true"></i>
							{{ strings.license_renew }}
						</a>
						<button type="button"
								id="LicenseLookup"
								class="btn btn-outline-primary license-action"
								data-action="lookup"
								{% if not flags.button_enabled_check %}disabled="disabled"{% endif %}>
							<i class="bi bi-arrow-repeat" aria-hidden="true"></i>
							{{ strings.check_license }}
						</button>
						<button type="button"
								class="btn btn-outline-danger license-action"
								data-action="clear"
								{% if not flags.button_enabled_check %}disabled="disabled"{% endif %}>
							<i class="bi bi-x-circle" aria-hidden="true"></i>
							{{ strings.clear_license }}
						</button>
					{% else %}
						<button type="button"
								id="LicenseLookup"
								class="btn btn-outline-primary license-action"
								data-action="lookup"
								{% if not flags.button_enabled_check %}disabled="disabled"{% endif %}>
							<i class="bi bi-arrow-repeat" aria-hidden="true"></i>
							{{ strings.check_license }}
						</button>
						<button type="button"
								class="btn btn-outline-danger license-action"
								data-action="clear"
								{% if not flags.button_enabled_check %}disabled="disabled"{% endif %}>
							<i class="bi bi-x-circle" aria-hidden="true"></i>
							{{ strings.clear_license }}
						</button>
					{% endif %}
					<button type="button"
							title="{{ strings.incase_debug }}"
							class="btn btn-outline-secondary license-action ms-auto"
							data-action="debug">
						<i class="bi bi-bug" aria-hidden="true"></i>
						{{ strings.debug }}
					</button>
				</div>
			</div>
		{% else %}
			<div class="sp-panel">
				<div class="sp-panel-accent accent-green"></div>
				<div class="row g-0">
					<div class="col-lg-5">
						<div class="action-panel">
							<div>
								<div class="ap-eyebrow">{{ strings.license_upgrade_eyebrow }}</div>
								<h2 class="ap-title">{{ strings.license_activate_title }}</h2>
								<p class="ap-sub">{{ strings.license_activate_subtitle }}</p>
							</div>

							<ul class="ap-steps">
								<li class="ap-step">
									<span class="ap-step-num">1</span>
									<div class="ap-step-text">
										<a target="_blank" rel="noopener noreferrer" href="{{ hrefs.keyless_cp }}">{{ strings.activate_site_in }}</a>
									</div>
								</li>
								<li class="ap-step">
									<span class="ap-step-num">2</span>
									<div class="ap-step-text">
										<div class="url-block-label">{{ strings.url_to_activate }}</div>
										<div class="url-block">{{ vars.activation_url }}</div>
									</div>
								</li>
								<li class="ap-step">
									<span class="ap-step-num">3</span>
									<div class="ap-step-text">
										{{ strings.license_check_limit }}.
										<small>{{ strings.more_frequent }}</small>
									</div>
								</li>
							</ul>

							<button type="button"
									id="LicenseLookup"
									class="btn btn-outline-primary license-action align-self-start"
									data-action="lookup"
									{% if not flags.button_enabled_check %}disabled="disabled"{% endif %}>
								<i class="bi bi-arrow-repeat" aria-hidden="true"></i>
								{{ strings.license_check_now }}
							</button>

							<a href="{{ hrefs.shield_pro_url }}"
							   target="_blank"
							   rel="noopener noreferrer"
							   class="pricing-link">
								{{ strings.license_pricing_plans }}
								<i class="bi bi-arrow-right" aria-hidden="true"></i>
							</a>
						</div>
						<div class="action-panel-footer">
							<button type="button"
									title="{{ strings.incase_debug }}"
									class="btn btn-outline-secondary license-action"
									data-action="debug">
								<i class="bi bi-bug" aria-hidden="true"></i>
								{{ strings.debug }}
							</button>
						</div>
					</div>

					<div class="col-auto col-sep d-none d-lg-block"></div>

					<div class="col-lg">
						<div class="gallery-panel">
							<div class="gallery-label">{{ strings.license_gallery_label }}</div>
							<div class="feat-gallery">
								{% for feature in vars.pro_feature_tiles %}
									<div class="feat-tile">
										<div class="feat-tile-icon">
											<i class="{{ imgs.svgs.thumbs_up }}" aria-hidden="true"></i>
										</div>
										<div class="feat-tile-body">
											<div class="feat-tile-title">{{ feature.title|raw }}</div>
											<div class="feat-tile-desc">{{ feature.description|raw }}</div>
										</div>
									</div>
								{% endfor %}
							</div>
							<div class="gallery-footer">
								<a href="https://clk.shldscrty.com/gp" target="_blank" rel="noopener noreferrer">
									{{ strings.cta_view_features }}
									<i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		{% endif %}
	</div>
{% endblock %}
