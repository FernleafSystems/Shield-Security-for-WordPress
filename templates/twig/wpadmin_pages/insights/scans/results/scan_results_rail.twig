{% set rail_tabs = vars.rail_tabs|default(vars.tabs|default([])) %}
{% set rail_accent = 'good' %}

{% for tab in rail_tabs %}
	{% if tab.key != 'summary' %}
		{% if tab.status|default('good') == 'critical' %}
			{% set rail_accent = 'critical' %}
		{% elseif tab.status|default('good') == 'warning' and rail_accent != 'critical' %}
			{% set rail_accent = 'warning' %}
		{% endif %}
	{% endif %}
{% endfor %}

{% set rail_items = [] %}
{% for tab in rail_tabs %}
	{% set rail_items = rail_items|merge([{
		key: tab.key,
		label: tab.label,
		status: tab.status|default('good'),
		count: tab.count|default(0),
		badge_status: tab.status|default('good'),
		is_active: tab.is_active|default(false),
		bootstrap_tab: true,
		use_aria_current: false,
		attributes: {
			id: tab.nav_id,
			role: 'tab',
			'data-bs-toggle': 'tab',
			'data-bs-target': tab.target,
			'aria-controls': tab.controls,
			'aria-selected': tab.is_active|default(false) ? 'true' : 'false'
		}
	}]) %}
{% endfor %}

{% set pane_content %}
	<div class="tab-content mb-3">
		{% for tab in rail_tabs %}
			<div class="tab-pane{% if tab.is_active|default(false) %} show active{% endif %}"
				 id="{{ tab.pane_id|e('html_attr') }}"
				 role="tabpanel"
				 aria-labelledby="{{ tab.nav_id|e('html_attr') }}"
				 data-shield-rail-pane="{{ tab.key|e('html_attr') }}"
				 data-actions-queue-pane-key="{{ tab.key|e('html_attr') }}"
				 data-actions-queue-pane-loaded="{{ tab.is_loaded|default(true) ? '1' : '0' }}"
				 data-actions-queue-render-action="{{ tab.render_action|default({})|json_encode|e('html_attr') }}">
				{% include '/wpadmin_pages/insights/scans/results/scan_results_rail_pane.twig' with {
					tab: tab,
					strings: strings,
					content: content
				} only %}
			</div>
		{% endfor %}
	</div>
{% endset %}

{% set rail_html %}
	{% include '/wpadmin/components/page/shield_rail_sidebar.twig' with { rail: {
		accent_status: rail_accent,
		id: 'ScanResultsRailSidebar',
		nav_attributes: {
			role: 'tablist',
			'aria-orientation': 'vertical'
		},
		items: rail_items
	} } only %}
{% endset %}

{% include '/wpadmin/components/page/shield_rail_layout.twig' with { layout: {
	rail_html: rail_html,
	content_html: pane_content
} } only %}
