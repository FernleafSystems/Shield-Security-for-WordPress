{% import '/common/macros.twig' as icwp_macros %}

<div class="shield-scan-pane-disabled alert alert-warning mb-0" data-shield-scan-pane-disabled="1">
	<div class="d-flex align-items-start">
		<i class="bi bi-slash-circle me-2"></i>
		<div class="flex-grow-1">
			<div>{{ message }}</div>
			{% if actions is not empty %}
				<div class="shield-detail-row__actions mt-3">
					{% for action in actions %}
						<a href="{{ action.href }}"
						   class="shield-action-chip shield-action-chip--{{ action.type }}{% if action.class_name is not empty %} {{ action.class_name }}{% endif %}"
						   data-shield-disabled-pane-action="1"
						   {% if action.tooltip_attr is not empty %}
						   data-bs-toggle="tooltip"
						   data-bs-title="{{ action.tooltip_attr|e('html_attr') }}"{% endif %}
						   {% if action.target is not empty %}target="{{ action.target|e('html_attr') }}"{% endif %}
						   {% if action.rel is not empty %}rel="{{ action.rel|e('html_attr') }}"{% endif %}{{ icwp_macros.renderAttributes(action.attributes) }}>
							<i class="{{ action.icon_class }}"></i>
							{{ action.label }}
						</a>
					{% endfor %}
				</div>
			{% endif %}
		</div>
	</div>
</div>
