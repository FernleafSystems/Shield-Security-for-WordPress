<ul class="nav nav-tabs shield_body-sub-nav" id="ScanResultsTabsNav" role="tablist">
	{% for tab in vars.tabs|default([]) %}
		<li class="nav-item">
			<a class="nav-link{% if tab.is_active|default(false) %} active{% endif %}"
			   id="{{ tab.nav_id }}"
			   data-bs-toggle="tab"
			   data-bs-target="{{ tab.target }}"
			   role="tab"
			   aria-controls="{{ tab.controls }}">
				{{ tab.label }}
				{% if tab.count > 0 %}
					<span class="badge bg-danger">{{ tab.count }}</span>
				{% else %}
					<span class="badge bg-success">&check;</span>
				{% endif %}
			</a>
		</li>
	{% endfor %}
</ul>

<div class="tab-content mb-3">
	{% for tab in vars.tabs|default([]) %}
		<div class="tab-pane{% if tab.is_active|default(false) %} show active{% endif %}"
			 id="{{ tab.pane_id }}"
			 role="tabpanel"
			 aria-labelledby="{{ tab.nav_id }}">
			{% if tab.key == 'summary' %}
				{% if vars.summary_rows|default([]) is not empty %}
					{% include '/wpadmin/components/actions_queue/summary_rows.twig' with {
						items: vars.summary_rows
					} only %}
				{% else %}
					{% include '/wpadmin/components/actions_queue/assessment_rows.twig' with {
						items: vars.assessment_rows|default([])
					} only %}
				{% endif %}
			{% elseif tab.key == 'vulnerabilities' %}
				{% set vulnerability_sections = vars.vulnerabilities.sections|default({}) %}
				<div class="scan-results-section mt-3">
					{% for section in vulnerability_sections %}
						{% if section.items|default([]) is not empty %}
							<div class="{% if not loop.first %}mt-3{% endif %}">
								<div class="shield-mode-strip__eyebrow mb-2">{{ section.label }}</div>
								{% include '/wpadmin/components/actions_queue/summary_rows.twig' with {
									items: section.items
								} only %}
							</div>
						{% endif %}
					{% endfor %}
				</div>
			{% elseif tab.key == 'wordpress' %}
				{{ content.section.wordpress|raw }}
			{% elseif tab.key == 'plugins' %}
				{{ content.section.plugins|raw }}
			{% elseif tab.key == 'themes' %}
				{{ content.section.themes|raw }}
			{% elseif tab.key == 'malware' %}
				{{ content.section.malware|raw }}
			{% elseif tab.key == 'file_locker' %}
				{{ content.section.filelocker|raw }}
			{% endif %}
		</div>
	{% endfor %}
</div>
