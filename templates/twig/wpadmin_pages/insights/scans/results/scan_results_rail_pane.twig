{% set is_loaded = tab.is_loaded is defined ? tab.is_loaded : true %}
{% set has_lazy_render_action = tab.render_action|default({}) is not empty %}
{% set is_lazy_placeholder = has_lazy_render_action and not is_loaded %}

{% if is_lazy_placeholder %}
	<div class="text-muted small" data-actions-queue-pane-placeholder="1">
		{{ strings.pane_loading|default('Loading scan details...') }}
	</div>
{% elseif tab.items|default([]) is empty %}
	<div class="shield-scan-pane-empty py-4 text-center text-muted">
		<i class="bi bi-check-circle fs-3 d-block mb-2"></i>
		{{ strings.no_issues|default('No issues found in this section.') }}
	</div>
{% else %}
	{% set current_section = null %}
	{% for item in tab.items %}

		{% if item.section_label|default(null) is not null and item.section_label != current_section %}
			{% set current_section = item.section_label %}
			<div class="shield-mode-strip__eyebrow mb-2{% if not loop.first %} mt-3{% endif %}">
				{{ current_section }}
			</div>
		{% endif %}

		<div class="shield-detail-item">
			{% include '/wpadmin/components/page/shield_detail_row.twig' with { row: {
				title: item.title|default(''),
				description: item.description|default(''),
				status: item.status|default('good'),
				status_icon: item.status_icon|default(null),
				status_label: item.status_label|default(null),
				count_badge: item.count_badge|default(null),
				badge_status: item.badge_status|default(null),
				expandable: item.expandable|default(false),
				expand_target: item.expand_target|default(''),
				explanations: item.explanations|default([]),
				show_gear: item.show_gear|default(false),
				actions: item.actions|default([])
			}} only %}
		</div>

		{% if item.expandable|default(false) and item.files|default([]) is not empty %}
			{% set file_table_body %}
				{% include '/wpadmin_pages/insights/scans/results/scan_file_table.twig' with { files: item.files } only %}
			{% endset %}
			{% include '/wpadmin/components/page/shield_detail_expansion.twig' with { expansion: {
				id: item.expand_target|default(''),
				type: 'table',
				status: item.status|default('warning'),
				body: file_table_body
			}} only %}
		{% endif %}

	{% endfor %}
{% endif %}
