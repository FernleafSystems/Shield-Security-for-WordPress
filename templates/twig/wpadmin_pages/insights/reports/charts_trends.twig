<div class="shield-reports-trends" data-reports-trends="1">
	<form id="ShieldReportsTrendsForm" class="card shield-reports-trends__card" data-reports-trends-form="1">
		<div class="card-header shield-reports-trends__card-header">
			<div class="shield-reports-trends__toolbar">
				<div class="shield-reports-trends__toolbar-main">
					<div class="shield-reports-trends__period-field">
						<label class="shield-reports-trends__field-label" for="ShieldReportsTrendsPeriod">{{ strings.period }}</label>
						<select id="ShieldReportsTrendsPeriod" class="form-select" name="period_key">
							{% for period in vars.periods %}
								<option value="{{ period.key }}"{% if period.is_default %} selected{% endif %}>{{ period.label }}</option>
							{% endfor %}
						</select>
					</div>

					<div class="shield-reports-trends__actions">
						<button class="btn btn-primary" type="submit" data-reports-chart-submit="1" disabled>{{ strings.update_chart }}</button>
						<p class="shield-reports-trends__selection-note mb-0" data-reports-chart-selection-note="1">{{ strings.selection_none }}</p>
					</div>
				</div>

				<div class="shield-reports-trends__events-block">
					<div class="shield-reports-trends__field-label mb-0">{{ strings.events }}</div>
					<div class="shield-reports-trends__event-chips">
						{% for event in vars.events %}
							{% set event_input_id = 'ShieldReportsTrendsEvent-' ~ loop.index %}
							<div class="shield-reports-trends__event-chip">
								<input id="{{ event_input_id }}" class="shield-reports-trends__event-input" type="checkbox" name="event_keys[]" value="{{ event.key }}">
								<label
									class="shield-reports-trends__event-label"
									for="{{ event_input_id }}"
									data-bs-toggle="tooltip"
									data-bs-trigger="hover focus"
									data-bs-placement="top"
									data-bs-title="{{ event.description|e('html_attr') }}"
								>{{ event.label }}</label>
							</div>
						{% endfor %}
					</div>
				</div>
			</div>
		</div>

		<div class="card-body shield-reports-trends__card-body">
			<div class="shield-reports-trends__chart-placeholder" data-reports-chart-empty="1">{{ strings.empty_state }}</div>
			<div class="alert alert-warning d-none mb-0" data-reports-chart-error="1"></div>

			<div class="d-none shield-reports-trends__results" data-reports-chart-results="1">
				<div class="shield-reports-trends__chart-meta mb-3">
					<div class="shield-reports-trends__legend-wrap d-none" data-reports-chart-legend-wrap="1">
						<div class="shield-reports-trends__legend-items" data-reports-chart-legend="1"></div>
					</div>
					<div class="shield-reports-trends__period-pill" data-reports-chart-period="1"></div>
				</div>
				<div class="shield-chart shield-reports-trends-chart" data-reports-chart-output="1"></div>
			</div>
		</div>
	</form>
</div>
