<div class="d-none shield_loading_placeholder shield-mode-nav-placeholder"
	 data-shield-nav-loading-placeholder="actions"
	 aria-hidden="true">
	<div class="load-wrapper shield-mode-nav-placeholder__loading-bar"><div class="activity"></div></div>
	<div class="shield-rail-layout shield-rail-layout--context-end shield-mode-nav-placeholder__layout">
		<div class="shield-rail-layout__content">
			<div class="operator-step-tabs shield-mode-nav-placeholder__breadcrumbs">
				<div class="operator-step-tabs__list">
					<div class="operator-step-tabs__tab shield-mode-nav-placeholder__crumb" data-color-key="actions">
						<div class="load-wrapper" style="width: 134px; height: 30px; border-radius: 999px;"><div class="activity"></div></div>
					</div>
					<div class="operator-step-tabs__tab shield-mode-nav-placeholder__crumb" data-color-key="actions">
						<div class="load-wrapper" style="width: 160px; height: 30px; border-radius: 999px;"><div class="activity"></div></div>
					</div>
					<div class="operator-step-tabs__tab shield-mode-nav-placeholder__crumb" data-color-key="actions">
						<div class="load-wrapper" style="width: 148px; height: 30px; border-radius: 999px;"><div class="activity"></div></div>
					</div>
				</div>
				<div class="operator-step-tabs__actions">
					<div class="load-wrapper shield-mode-nav-placeholder__action" style="width: 38px; height: 38px; border-radius: 999px;"><div class="activity"></div></div>
				</div>
			</div>

			<div class="actions-queue-asset-cards">
				<div class="investigate-landing__subject-grid actions-queue-asset-cards__grid">
					{% for i in 1..4 %}
						<div class="investigate-landing__subject-card actions-queue-asset-card status-info shield-mode-nav-placeholder__card">
							<div class="load-wrapper mb-3" style="width: 44px; height: 44px; border-radius: 12px;"><div class="activity"></div></div>
							<div class="load-wrapper mb-2" style="width: {{ [74, 78, 70, 76][loop.index0] }}%; height: 16px;"><div class="activity"></div></div>
							<div class="load-wrapper" style="width: {{ [52, 56, 48, 50][loop.index0] }}%; height: 12px;"><div class="activity"></div></div>
						</div>
					{% endfor %}
				</div>

				<div class="actions-queue-asset-panel shield-mode-nav-placeholder__summary-panel">
					<div class="actions-queue-asset-panel__summary">
						<div class="actions-queue-asset-panel__copy w-100">
							<div class="load-wrapper mb-2" style="width: 44%; height: 14px;"><div class="activity"></div></div>
							<div class="load-wrapper" style="width: 28%; height: 12px;"><div class="activity"></div></div>
						</div>
					</div>
					<div class="actions-queue-asset-panel__body">
						<div class="load-wrapper mb-3" style="width: 100%; height: 42px;"><div class="activity"></div></div>
						{% for i in 1..5 %}
							<div class="load-wrapper mb-2" style="width: {{ [92, 86, 96, 78, 88][loop.index0] }}%; height: 16px;"><div class="activity"></div></div>
						{% endfor %}
					</div>
				</div>
			</div>
		</div>
		<div class="shield-rail-layout__sidebar shield-mode-nav-placeholder__sidebar"></div>
	</div>
</div>

